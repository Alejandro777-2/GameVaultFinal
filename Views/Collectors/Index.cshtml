@model ComunidadIndexViewModel
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Comunidad de Coleccionistas";
}

@functions {
    static string PinColor(int index) => index switch
    {
        0 => "#5B2C9E",
        1 => "#FF6B6B",
        2 => "#3B6D11",
        3 => "#06B6D4",
        _ => "#FFD23F"
    };

    static string Initials(string displayName)
    {
        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
            : displayName.Substring(0, Math.Min(2, displayName.Length)).ToUpperInvariant();
    }
}

<div class="d-flex justify-content-between align-items-start mb-2 flex-wrap gap-2">
    <div>
        <h1 class="mb-1">MAPA DE COLECCIONISTAS</h1>
        <p class="px-font mb-0" style="font-size:0.85rem; color:var(--gv-muted)">
            &#9733; Comunidad GameVault en Latinoamérica
        </p>
    </div>
    <span class="px-badge px-badge-yellow">&#128205; QUITO, ECUADOR</span>
</div>

<div class="row mt-4 g-4">
    <div class="col-lg-7">
        <div id="collectors-map"
             style="width:100%; height:700px; border:2px solid var(--gv-ink); box-shadow:var(--gv-shadow-y)">
        </div>
        @if (!Model.MapMarkers.Any())
        {
            <div class="px-card p-4 mt-3 text-center">
                <p class="px-font mb-1 fw-bold">Ningún coleccionista ha compartido su ubicación aún.</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <p class="mb-2" style="color:var(--gv-muted); font-size:0.85rem">
                        Puedes añadir tu ciudad en tu perfil para aparecer aquí.
                    </p>
                    <a asp-area="Identity" asp-page="/Account/Manage/Index"
                       class="px-btn px-btn-primary px-btn-sm">IR A MI PERFIL</a>
                }
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="px-card p-3 mb-3" style="background:var(--gv-yellow-soft)">
            <p class="px-section-title mb-2">CERCA DE TI &middot; @Model.Collectors.Count</p>
            <div class="d-flex gap-2 flex-wrap">
                <span class="px-badge px-badge-yellow">DISTANCIA &#9660;</span>
                <span class="px-badge px-badge-purple">NES</span>
                <span class="px-badge px-badge-cyan">SNES</span>
                <span class="px-badge px-badge-green">N64</span>
                <span class="px-badge px-badge-coral">PS1</span>
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            @{
                int sideIdx = 0;
                foreach (var entry in Model.Collectors)
                {
                    var color = PinColor(sideIdx);
                    var initials = Initials(entry.User.DisplayName);
                    var location = string.Join(", ",
                        new[] { entry.User.City, entry.User.Country }
                            .Where(s => !string.IsNullOrWhiteSpace(s)));
                    <div class="px-card p-3 d-flex align-items-center gap-3">
                        <div class="flex-shrink-0 d-flex align-items-center justify-content-center px-font fw-bold"
                             style="width:44px; height:44px; background:@color; color:#fff; border:2px solid var(--gv-ink); font-size:0.85rem">
                            @initials
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <p class="px-font fw-bold mb-0 text-truncate" style="font-size:0.9rem">
                                <a asp-controller="Users" asp-action="Profile"
                                   asp-route-id="@entry.User.Id"
                                   class="text-decoration-none" style="color:var(--gv-ink)">
                                    @entry.User.DisplayName
                                </a>
                            </p>
                            @if (!string.IsNullOrWhiteSpace(location))
                            {
                                <p class="mb-0 px-font" style="font-size:0.75rem; color:var(--gv-muted)">
                                    &#128205; @location
                                </p>
                            }
                            <div class="d-flex gap-1 flex-wrap mt-1">
                                <span class="px-badge px-badge-yellow">@entry.ActiveAssetCount activos</span>
                                @foreach (var p in entry.TopPlatforms)
                                {
                                    <span class="px-badge" style="background:#fff; color:var(--gv-ink)">
                                        @p.GetDisplayName()
                                    </span>
                                }
                            </div>
                        </div>
                        <a asp-controller="Users" asp-action="Profile"
                           asp-route-id="@entry.User.Id"
                           class="px-btn px-btn-secondary px-btn-sm flex-shrink-0">VER</a>
                    </div>
                    sideIdx++;
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    var gvCollectors = @Html.Raw(Json.Serialize(Model.MapMarkers));

    function initMap() {
        var map = new google.maps.Map(document.getElementById('collectors-map'), {
            center: { lat: -1.83, lng: -78.18 },
            zoom: 7,
            mapTypeControl: false,
            fullscreenControl: false,
            streetViewControl: false,
            styles: [
                { featureType: 'poi', stylers: [{ visibility: 'off' }] },
                { featureType: 'transit', stylers: [{ visibility: 'off' }] },
                { elementType: 'geometry', stylers: [{ color: '#f5f5f0' }] },
                { elementType: 'labels.text.fill', stylers: [{ color: '#1A1A2E' }] },
                { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#06B6D4' }] },
                { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#e5e5e0' }] },
                { featureType: 'road', elementType: 'geometry.stroke', stylers: [{ color: '#1A1A2E' }] }
            ]
        });

        var pinSvg = '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="28" viewBox="0 0 22 28">'
            + '<rect x="1" y="1" width="20" height="20" rx="0" fill="#5B2C9E" stroke="#1A1A2E" stroke-width="2"/>'
            + '<polygon points="11,27 6,21 16,21" fill="#5B2C9E" stroke="#1A1A2E" stroke-width="1.5" stroke-linejoin="round"/>'
            + '<rect x="7" y="10" width="8" height="2" fill="#FFD23F"/>'
            + '<rect x="10" y="7" width="2" height="8" fill="#FFD23F"/>'
            + '</svg>';
        var pinUrl = 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(pinSvg);

        var openWindow = null;

        gvCollectors.forEach(function (c) {
            var marker = new google.maps.Marker({
                position: { lat: c.latitude, lng: c.longitude },
                map: map,
                title: c.displayName,
                icon: {
                    url: pinUrl,
                    scaledSize: new google.maps.Size(22, 28),
                    anchor: new google.maps.Point(11, 27)
                }
            });

            var assetLabel = c.activeAssetCount === 1
                ? '1 activo en catálogo'
                : c.activeAssetCount + ' activos en catálogo';

            var cityLine = c.city
                ? '<div style="color:#6B6B7B;margin-bottom:4px">&#128205; ' + c.city + '</div>'
                : '';

            var content = '<div style="'
                + 'font-family:Courier New,monospace;'
                + 'border:2px solid #1A1A2E;'
                + 'box-shadow:3px 3px 0 #1A1A2E;'
                + 'padding:12px 14px;'
                + 'background:#fff;'
                + 'min-width:180px;'
                + 'max-width:240px;'
                + '">'
                + '<div style="font-weight:800;font-size:0.9rem;color:#1A1A2E;margin-bottom:6px">'
                + c.displayName
                + '</div>'
                + cityLine
                + '<div style="color:#5B2C9E;font-size:0.8rem;font-weight:700">&#127918; ' + assetLabel + '</div>'
                + '<a href="/Users/Profile/' + c.userId + '" '
                + 'style="display:inline-block;margin-top:8px;font-size:0.75rem;color:#5B2C9E;text-decoration:none;border-bottom:1px solid #5B2C9E">'
                + 'Ver perfil &#8599;</a>'
                + '</div>';

            var infoWindow = new google.maps.InfoWindow({ content: content, disableAutoPan: false });

            marker.addListener('click', function () {
                if (openWindow) openWindow.close();
                infoWindow.open(map, marker);
                openWindow = infoWindow;
            });
        });

        map.addListener('click', function () {
            if (openWindow) { openWindow.close(); openWindow = null; }
        });
    }
</script>
<script src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleMaps:ApiKey"]&callback=initMap"
        async defer></script>
}
