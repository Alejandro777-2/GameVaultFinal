@model AssetFormViewModel
@{
    ViewData["Title"] = "Editar activo";
}

<div class="mb-3">
    <a asp-action="Details" asp-route-id="@Model.Id" class="px-btn px-btn-secondary px-btn-sm">&#8592; VOLVER</a>
</div>

<h1>EDITAR ACTIVO</h1>

<div class="row mt-4">
    <div class="col-12 col-lg-7">
        <div class="px-card-accent p-4">
            <span class="px-badge px-badge-yellow mb-3 d-inline-block">+ EDIT</span>

            <form method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)
                <div asp-validation-summary="ModelOnly" class="alert alert-danger px-alert mb-4" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Platform" class="form-label"></label>
                        <select asp-for="Platform" class="form-select"
                                asp-items="Html.GetEnumSelectList<Platform>()">
                            <option value="">-- Seleccione --</option>
                        </select>
                        <span asp-validation-for="Platform" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Region" class="form-label"></label>
                        <select asp-for="Region" class="form-select"
                                asp-items="Html.GetEnumSelectList<Region>()">
                            <option value="">-- Seleccione --</option>
                        </select>
                        <span asp-validation-for="Region" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Condition" class="form-label"></label>
                        <select asp-for="Condition" class="form-select"
                                asp-items="Html.GetEnumSelectList<Condition>()">
                            <option value="">-- Seleccione --</option>
                        </select>
                        <span asp-validation-for="Condition" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Year" class="form-label"></label>
                        <input asp-for="Year" class="form-control"
                               type="number" min="1970" max="2010" />
                        <span asp-validation-for="Year" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">TIPO DE OFERTA</label>
                    <div class="px-card p-3 d-flex gap-4 flex-wrap" style="background:var(--gv-yellow-soft)">
                        <label class="px-font d-flex align-items-center gap-2" style="cursor:pointer; font-size:0.85rem; font-weight:800">
                            <input type="radio" asp-for="OfferType" value="0" /> Venta
                        </label>
                        <label class="px-font d-flex align-items-center gap-2" style="cursor:pointer; font-size:0.85rem; font-weight:800">
                            <input type="radio" asp-for="OfferType" value="1" /> Intercambio
                        </label>
                        <label class="px-font d-flex align-items-center gap-2" style="cursor:pointer; font-size:0.85rem; font-weight:800">
                            <input type="radio" asp-for="OfferType" value="2" /> Venta o Intercambio
                        </label>
                    </div>
                </div>

                <div id="price-group" class="mb-3">
                    <label asp-for="EstimatedValue" class="form-label"></label>
                    <input asp-for="EstimatedValue" class="form-control"
                           type="number" step="0.01" min="0" max="99999" />
                    <span asp-validation-for="EstimatedValue" class="text-danger small"></span>
                </div>

                <div id="trade-wants-group" class="mb-3" style="display:none">
                    <label asp-for="TradeWants" class="form-label"></label>
                    <textarea asp-for="TradeWants" class="form-control" style="height:80px"
                              placeholder="¿Qué te gustaría recibir a cambio?"></textarea>
                    <span asp-validation-for="TradeWants" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label"></label>
                    @if (!string.IsNullOrEmpty(Model.CurrentImageUrl))
                    {
                        <div class="mb-2 px-card p-2 d-inline-block">
                            <img src="@Model.CurrentImageUrl" style="max-height:100px; display:block"
                                 alt="Imagen actual" />
                            <p class="px-font mb-0 mt-1" style="font-size:0.7rem; color:var(--gv-muted)">
                                Imagen actual — suba una nueva para reemplazarla.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-4 mb-2"
                             style="border:3px dashed var(--gv-ink); background:var(--gv-yellow-soft)">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                                 stroke="var(--gv-ink)" stroke-width="2" stroke-linecap="square">
                                <rect x="3" y="3" width="18" height="18"/>
                                <circle cx="8.5" cy="8.5" r="1.5" fill="var(--gv-ink)" stroke="none"/>
                                <polyline points="21,15 16,10 5,21"/>
                            </svg>
                            <p class="mt-2 mb-0 px-font" style="font-size:0.8rem; color:var(--gv-muted)">
                                Cargar imagen del activo
                            </p>
                        </div>
                    }
                    <input type="file" asp-for="ImageFile" class="form-control"
                           accept=".jpg,.jpeg,.png,.webp" />
                    <small class="px-font" style="color:var(--gv-muted); font-size:0.75rem">
                        Formatos: JPG, PNG, WEBP. Máximo 5 MB.
                    </small>
                    <span asp-validation-for="ImageFile" class="text-danger small d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" style="height:120px"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="px-btn px-btn-primary">&#128190; GUARDAR</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="px-btn px-btn-secondary">CANCELAR</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        function updateOfferUi() {
            var val = document.querySelector('input[name="OfferType"]:checked')?.value;
            var priceGroup = document.getElementById('price-group');
            var tradeGroup = document.getElementById('trade-wants-group');
            if (val === '1') {
                priceGroup.style.display = 'none';
                tradeGroup.style.display = '';
            } else if (val === '2') {
                priceGroup.style.display = '';
                tradeGroup.style.display = '';
            } else {
                priceGroup.style.display = '';
                tradeGroup.style.display = 'none';
            }
        }
        document.querySelectorAll('input[name="OfferType"]').forEach(function (r) {
            r.addEventListener('change', updateOfferUi);
        });
        updateOfferUi();
    })();
    </script>
}
