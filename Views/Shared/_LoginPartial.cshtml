@using Microsoft.AspNetCore.Identity
@using GameVault.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = currentUser?.DisplayName ?? User.Identity?.Name ?? "Usuario";
    <a class="px-badge px-badge-yellow text-decoration-none"
       asp-area="Identity" asp-page="/Account/Manage/Index"
       title="Gestionar cuenta">@displayName</a>
    <form class="d-inline m-0" asp-area="Identity" asp-page="/Account/Logout"
          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
        <button type="submit" class="px-btn px-btn-secondary px-btn-sm">CERRAR SESIÓN</button>
    </form>
}
else
{
    <a class="gv-nav-link" asp-area="Identity" asp-page="/Account/Login">INICIAR SESIÓN</a>
    <a class="px-btn px-btn-primary px-btn-sm" asp-area="Identity" asp-page="/Account/Register">CREAR CUENTA</a>
}
</div>
