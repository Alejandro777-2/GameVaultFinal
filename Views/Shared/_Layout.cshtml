<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameVault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GameVault.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var action = ViewContext.RouteData.Values["action"]?.ToString()     ?? "";

        string NavCls(string c, string a = "") =>
            ctrl.Equals(c, StringComparison.OrdinalIgnoreCase) &&
            (string.IsNullOrEmpty(a) || action.Equals(a, StringComparison.OrdinalIgnoreCase))
                ? "gv-nav-link active"
                : "gv-nav-link";

    }
    <header>
        <nav class="gv-navbar navbar navbar-expand-sm py-2">
            <div class="container-fluid px-4">
                <a class="navbar-brand p-0 text-decoration-none"
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <partial name="_PixelLogo" />
                </a>
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Abrir menú">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex align-items-center justify-content-between">
                    <ul class="navbar-nav gap-4 ms-4">
                        <li class="nav-item">
                            <a class="@NavCls("Home", "Index")"
                               asp-area="" asp-controller="Home" asp-action="Index">INICIO</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavCls("Assets")"
                               asp-controller="Assets" asp-action="Index">CATÁLOGO</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center gap-1">
                                <a class="@NavCls("Wishlist")"
                                   asp-controller="Wishlist" asp-action="Index">WISHLIST</a>
                                @await Component.InvokeAsync("WishlistCount")
                            </li>
                        }
                        <li class="nav-item">
                            <a class="@NavCls("Collectors")"
                               asp-controller="Collectors" asp-action="Index">COMUNIDAD</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavCls("Marketplace")"
                               asp-controller="Marketplace" asp-action="Index">MARKETPLACE</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavCls("Home", "Privacy")"
                               asp-area="" asp-controller="Home" asp-action="Privacy">PRIVACIDAD</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main" class="pb-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div id="success-alert" class="alert alert-success alert-dismissible fade show px-alert mb-4" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show px-alert mb-4" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="gv-footer">
        <div class="container">
            &copy; 2026 GAMEVAULT &#9733; NEXUS ASSET LABS
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var el = document.getElementById('success-alert');
            if (el) setTimeout(function () { bootstrap.Alert.getOrCreateInstance(el).close(); }, 5000);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
