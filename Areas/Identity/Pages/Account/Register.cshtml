@page
@model RegisterModel
@{
    ViewData["Title"] = "Registrarse";
}

<div class="row justify-content-center py-4">
    <div class="col-md-5 col-lg-4">
        <div class="px-card-accent p-4">
            <span class="px-badge px-badge-purple mb-3 d-inline-block">&#9733; NUEVA CUENTA</span>
            <h1 class="mb-4">REGISTRARSE</h1>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger px-alert mb-3" role="alert"></div>

                <div class="mb-3">
                    <label class="form-label">Correo electrónico</label>
                    <input asp-for="Input.Email" class="form-control"
                           autocomplete="username" aria-required="true" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nombre para mostrar</label>
                    <input asp-for="Input.DisplayName" class="form-control"
                           autocomplete="nickname" aria-required="true" />
                    <span asp-validation-for="Input.DisplayName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input asp-for="Input.Password" class="form-control"
                           autocomplete="new-password" aria-required="true" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Confirmar contraseña</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control"
                           autocomplete="new-password" aria-required="true" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button id="registerSubmit" type="submit" class="px-btn px-btn-primary w-100 mb-3 text-center">
                    CREAR CUENTA
                </button>
            </form>

            <hr class="px-divider">
            <div class="text-center">
                <p class="px-font mb-2" style="font-size:0.8rem; color:var(--gv-muted)">
                    &mdash; ¿Ya tienes cuenta? &mdash;
                </p>
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl"
                   class="px-btn px-btn-secondary px-btn-sm">INICIAR SESIÓN</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
