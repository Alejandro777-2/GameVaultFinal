@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="row justify-content-center py-4">
    <div class="col-md-5 col-lg-4">
        <div class="px-card-accent p-4">
            <span class="px-badge px-badge-purple mb-3 d-inline-block">&#9733; ACCESO</span>
            <h1 class="mb-4">INICIAR SESIÓN</h1>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger px-alert mb-3" role="alert"></div>

                <div class="mb-3">
                    <label class="form-label">Correo electrónico</label>
                    <input asp-for="Input.Email" class="form-control"
                           autocomplete="username" aria-required="true" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input asp-for="Input.Password" class="form-control"
                           autocomplete="current-password" aria-required="true" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="d-flex align-items-center gap-2"
                           style="font-family:'Courier New',monospace; font-size:0.8rem; font-weight:700; text-transform:uppercase; cursor:pointer">
                        <input class="form-check-input m-0" asp-for="Input.RememberMe"
                               style="width:18px; height:18px; border:2px solid var(--gv-ink); border-radius:0; flex-shrink:0" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <button id="login-submit" type="submit" class="px-btn px-btn-primary w-100 mb-3 text-center">
                    INICIAR SESIÓN
                </button>
            </form>

            <hr class="px-divider">
            <div class="text-center">
                <p class="px-font mb-2" style="font-size:0.8rem; color:var(--gv-muted)">
                    &mdash; ¿No tienes cuenta? &mdash;
                </p>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                   class="px-btn px-btn-secondary px-btn-sm">CREAR CUENTA</a>
            </div>

            <div class="mt-3 text-center">
                <a id="forgot-password" asp-page="./ForgotPassword"
                   class="px-font" style="font-size:0.75rem; color:var(--gv-muted)">
                    ¿Olvidó su contraseña?
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
